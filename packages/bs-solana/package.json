    "@solana-program/token": "0.13.0",
    "@solana/kit": "~6.8.0",
    "axios": "1.16.0",
    "date-fns": "~4.1.0",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@ledgerhq/hw-transport-node-hid": "~6.33.1",
    "@types/node": "~25.6.0",
    "dotenv": "~17.4.2",
    "eslint": "~10.3.0",
    "typescript": "~6.0.3",
    "vitest": "~4.1.5"
  }
}
